{
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 4201,
    "controlUi": false,
    "auth": {
      "token": {
        "$secretRef": "OPENCLAW_GATEWAY_TOKEN"
      }
    }
  },
  "model": {
    "primary": "openai-codex/gpt-5.3-codex",
    "fallback": "openai-codex/gpt-5-codex"
  },
  "hooks": {
    "enabled": true,
    "path": "/hooks",
    "token": {
      "$secretRef": "OPENCLAW_HOOK_TOKEN"
    },
    "defaultSessionKey": "hook:stage:dispatch",
    "allowRequestSessionKey": false,
    "allowedSessionKeyPrefixes": [
      "hook:stage:"
    ],
    "allowedAgentIds": [
      "ceo",
      "ops"
    ],
    "mappings": [
      {
        "name": "dispatch-immediate",
        "match": {
          "path": "dispatch"
        },
        "action": "agent",
        "agentId": "ceo",
        "wakeMode": "now",
        "sessionKey": "hook:stage:dispatch:ceo",
        "deliver": false,
        "model": "openai-codex/gpt-5.3-codex",
        "messageTemplate": "Dispatch continuation requested. Review dispatch-state.json and continue the next ready task immediately. Completed task: {{completedTaskId}}. Next task: {{nextTaskId}}."
      }
    ]
  },
  "agents": {
    "defaults": {
      "workspace": "/opt/revenue-os/runtime/stage/workspace",
      "userTimezone": "Europe/London",
      "timeFormat": "en-GB"
    },
    "list": [
      {
        "name": "ceo",
        "workspace": "/opt/revenue-os/runtime/stage/workspace/ceo",
        "agentDir": "/opt/revenue-os/agents/ceo",
        "model": "openai-codex/gpt-5.3-codex",
        "heartbeat": {
          "every": "12m",
          "model": "openai-codex/gpt-5.3-codex",
          "prompt": "Read HEARTBEAT.md and data/exports/dispatch-state.json. Continue only if a ready task exists, a blocker cleared, or the queue needs reprioritization. Keep the acknowledgement terse.",
          "session": "main",
          "includeReasoning": false,
          "directPolicy": "block",
          "target": "none",
          "ackMaxChars": 180,
          "suppressToolErrorWarnings": true
        }
      },
      {
        "name": "research",
        "workspace": "/opt/revenue-os/runtime/stage/workspace/research",
        "agentDir": "/opt/revenue-os/agents/research",
        "model": "openai-codex/gpt-5.3-codex",
        "heartbeat": {
          "every": "15m",
          "model": "openai-codex/gpt-5.3-codex",
          "prompt": "Read HEARTBEAT.md and data/exports/dispatch-state.json. Continue only if a ready task exists, a blocker cleared, or the queue needs reprioritization. Keep the acknowledgement terse.",
          "session": "main",
          "includeReasoning": false,
          "directPolicy": "block",
          "target": "none",
          "ackMaxChars": 180,
          "suppressToolErrorWarnings": true
        }
      },
      {
        "name": "builder",
        "workspace": "/opt/revenue-os/runtime/stage/workspace/builder",
        "agentDir": "/opt/revenue-os/agents/builder",
        "model": "openai-codex/gpt-5.3-codex",
        "heartbeat": {
          "every": "12m",
          "model": "openai-codex/gpt-5.3-codex",
          "prompt": "Read HEARTBEAT.md and data/exports/dispatch-state.json. Continue only if a ready task exists, a blocker cleared, or the queue needs reprioritization. Keep the acknowledgement terse.",
          "session": "main",
          "includeReasoning": false,
          "directPolicy": "block",
          "target": "none",
          "ackMaxChars": 180,
          "suppressToolErrorWarnings": true
        }
      },
      {
        "name": "distribution",
        "workspace": "/opt/revenue-os/runtime/stage/workspace/distribution",
        "agentDir": "/opt/revenue-os/agents/distribution",
        "model": "openai-codex/gpt-5.3-codex",
        "heartbeat": {
          "every": "20m",
          "model": "openai-codex/gpt-5.3-codex",
          "prompt": "Read HEARTBEAT.md and data/exports/dispatch-state.json. Continue only if a ready task exists, a blocker cleared, or the queue needs reprioritization. Keep the acknowledgement terse.",
          "session": "main",
          "includeReasoning": false,
          "directPolicy": "block",
          "target": "none",
          "ackMaxChars": 180,
          "suppressToolErrorWarnings": true
        }
      },
      {
        "name": "treasury",
        "workspace": "/opt/revenue-os/runtime/stage/workspace/treasury",
        "agentDir": "/opt/revenue-os/agents/treasury",
        "model": "openai-codex/gpt-5.3-codex",
        "heartbeat": {
          "every": "30m",
          "model": "openai-codex/gpt-5.3-codex",
          "prompt": "Read HEARTBEAT.md and data/exports/dispatch-state.json. Continue only if a ready task exists, a blocker cleared, or the queue needs reprioritization. Keep the acknowledgement terse.",
          "session": "main",
          "includeReasoning": false,
          "directPolicy": "block",
          "target": "none",
          "ackMaxChars": 180,
          "suppressToolErrorWarnings": true
        }
      },
      {
        "name": "skillsmith",
        "workspace": "/opt/revenue-os/runtime/stage/workspace/skillsmith",
        "agentDir": "/opt/revenue-os/agents/skillsmith",
        "model": "openai-codex/gpt-5.3-codex",
        "heartbeat": {
          "every": "25m",
          "model": "openai-codex/gpt-5.3-codex",
          "prompt": "Read HEARTBEAT.md and data/exports/dispatch-state.json. Continue only if a ready task exists, a blocker cleared, or the queue needs reprioritization. Keep the acknowledgement terse.",
          "session": "main",
          "includeReasoning": false,
          "directPolicy": "block",
          "target": "none",
          "ackMaxChars": 180,
          "suppressToolErrorWarnings": true
        }
      },
      {
        "name": "ops",
        "workspace": "/opt/revenue-os/runtime/stage/workspace/ops",
        "agentDir": "/opt/revenue-os/agents/ops",
        "model": "openai-codex/gpt-5.3-codex",
        "heartbeat": {
          "every": "12m",
          "model": "openai-codex/gpt-5.3-codex",
          "prompt": "Read HEARTBEAT.md and data/exports/dispatch-state.json. Continue only if a ready task exists, a blocker cleared, or the queue needs reprioritization. Keep the acknowledgement terse.",
          "session": "main",
          "includeReasoning": false,
          "directPolicy": "block",
          "target": "none",
          "ackMaxChars": 180,
          "suppressToolErrorWarnings": true
        }
      }
    ]
  },
  "browser": {
    "defaultProfile": "openclaw",
    "profiles": {
      "openclaw": {
        "headless": false
      },
      "chrome": {
        "mode": "attached"
      }
    }
  },
  "cron": {
    "enabled": true
  },
  "heartbeat": {
    "enabled": true,
    "policy": "strategic-sweep-only",
    "notes": "Heartbeat stays lightweight because immediate continuation flows through runtime:complete-task plus the wake hook."
  }
}
