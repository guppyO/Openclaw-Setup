[Unit]
Description=Revenue OS source-refresh stage
After=network-online.target

[Service]
Type=oneshot
User=revenueos
Group=revenueos
WorkingDirectory=/opt/revenue-os
Environment=NODE_ENV=production
Environment=REVENUE_OS_ENVIRONMENT=stage
EnvironmentFile=-/opt/revenue-os/.secrets/revenue-os.local.env
ExecStart=/usr/bin/env bash -lc 'cd /opt/revenue-os && npm run refresh:updates'
