[Unit]
Description=Revenue OS OpenClaw stage gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=revenueos
Group=revenueos
WorkingDirectory=/opt/revenue-os
Environment=NODE_ENV=production
Environment=REVENUE_OS_ENVIRONMENT=stage
EnvironmentFile=-/opt/revenue-os/.secrets/revenue-os.local.env
Environment=OPENCLAW_CONFIG_PATH=/opt/revenue-os/data/generated/openclaw/stage.json
ExecStartPre=/usr/bin/env bash -lc 'cd /opt/revenue-os && npm run runtime:probe-models -- --active && npm run bootstrap:control-plane'
ExecStartPre=/usr/bin/env bash -lc 'cd /opt/revenue-os && npm run runtime:render-openclaw-config -- --environment stage --output /opt/revenue-os/data/generated/openclaw/stage.json'
ExecStartPre=/usr/bin/env bash -lc 'cd /opt/revenue-os && npm run verify:openclaw-config -- stage'
ExecStartPre=/usr/bin/env bash -lc 'cd /opt/revenue-os && OPENCLAW_CONFIG_PATH=/opt/revenue-os/data/generated/openclaw/stage.json openclaw doctor'
ExecStart=/usr/bin/env openclaw gateway --config /opt/revenue-os/data/generated/openclaw/stage.json
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
