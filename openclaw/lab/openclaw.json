  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai-codex/gpt-5.4",
        "fallbacks": []
      },
      "models": {
        "openai-codex/gpt-5.4": {
          "alias": "frontier",
          "params": {
            "reasoning": {
              "effort": "high"
            }
          }
        }
      },
      "workspace": "/opt/revenue-os/runtime/lab/workspace",
      "userTimezone": "Europe/London",
      "timeFormat": "24",
      "thinkingDefault": "high",
      "timeoutSeconds": 1800,
      "contextTokens": 900000,
      "maxConcurrent": 4,
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "55m"
      },
      "compaction": {
        "mode": "safeguard",
        "reserveTokensFloor": 32000,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 8000,
          "systemPrompt": "Session nearing compaction. Store durable memories now.",
          "prompt": "Write lasting notes to memory and initiative docs. Reply with NO_REPLY if nothing durable changed."
        }
      },
      "memorySearch": {
        "enabled": true,
        "sources": [
          "memory"
        ],
        "extraPaths": [
          "initiatives"
        ],
        "experimental": {
          "sessionMemory": false
        },
        "provider": "local",
        "local": {
          "modelPath": "hf:ggml-org/embeddinggemma-300m-qat-q8_0-GGUF/embeddinggemma-300m-qat-Q8_0.gguf",
          "modelCacheDir": "/opt/revenue-os/runtime/models/embeddings"
        },
        "fallback": "none",
        "store": {
          "path": "/opt/revenue-os/runtime/lab/memory/{agentId}.sqlite",
          "vector": {
            "enabled": true
          }
        }
      }
    },
    "list": [
      {
        "id": "ceo",
        "name": "ceo",
        "workspace": "/opt/revenue-os/runtime/lab/workspace/ceo",
        "agentDir": "/opt/revenue-os/agents/ceo",
        "model": {
          "primary": "openai-codex/gpt-5.4",
          "fallbacks": []
        },
        "identity": {
          "name": "ceo"
        },
        "heartbeat": {
          "every": "12m",
          "model": "openai-codex/gpt-5.4",
          "prompt": "Read HEARTBEAT.md and data/exports/dispatch-state.json. Continue only if a ready task exists, a blocker cleared, or the queue needs reprioritization. Keep the acknowledgement terse.",
          "session": "main",
          "includeReasoning": false,
          "directPolicy": "block",
          "target": "none",
          "ackMaxChars": 180,
          "suppressToolErrorWarnings": true
        }
      },
