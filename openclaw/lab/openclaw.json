{
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 4101,
    "controlUi": {
      "enabled": true
    },
    "auth": {
      "mode": "token",
      "token": "__OPENCLAW_GATEWAY_TOKEN__"
    }
  },
  "hooks": {
    "enabled": true,
    "path": "/hooks",
    "token": "__OPENCLAW_HOOK_TOKEN__",
    "defaultSessionKey": "hook:lab:dispatch",
    "allowRequestSessionKey": false,
    "allowedSessionKeyPrefixes": [
      "hook:lab:"
    ],
    "allowedAgentIds": [
      "ceo",
      "research",
      "builder",
      "distribution",
      "treasury",
      "skillsmith",
      "ops"
    ],
    "mappings": [
      {
        "name": "dispatch-immediate-ceo",
        "match": {
          "path": "dispatch/ceo"
        },
        "action": "agent",
        "agentId": "ceo",
        "wakeMode": "now",
        "sessionKey": "hook:lab:dispatch:ceo",
        "deliver": false,
        "model": "openai-codex/gpt-5.4",
        "thinking": "xhigh",
        "messageTemplate": "Dispatch continuation requested. Review dispatch-state.json and continue your active assignment(s) immediately. Completed task: {{completedTaskId}}. Primary task: {{targetTaskId}}. Active tasks: {{targetTaskIds}}."
      },
      {
        "name": "dispatch-immediate-research",
        "match": {
          "path": "dispatch/research"
        },
