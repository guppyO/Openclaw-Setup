        "model": "openai-codex/gpt-5.4",
        "thinking": "xhigh",
        "messageTemplate": "Dispatch continuation requested. Review dispatch-state.json and continue your active assignment(s) immediately. Completed task: {{completedTaskId}}. Primary task: {{targetTaskId}}. Active tasks: {{targetTaskIds}}."
      },
